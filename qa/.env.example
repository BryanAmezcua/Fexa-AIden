# Copy to .env and fill in. .env is gitignored.

# Environment under test. Swap between local and QA by changing this value
# (or by creating .env.local and .env.qa and copying the right one to .env).
TEST_BASE_URL=http://localhost:3000

# --- Test account credentials per role ---
# Each role needs its own account in the target environment.
# Empty roles are skipped by global-setup (no auth file produced).

ADMIN_EMAIL=
ADMIN_PASSWORD=

VENDOR_EMAIL=
VENDOR_PASSWORD=

FACILITY_MANAGER_EMAIL=
FACILITY_MANAGER_PASSWORD=
